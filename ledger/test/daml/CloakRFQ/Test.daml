-- | CloakRFQ Receipts - Daml Script tests.
--
-- Phase 1 (#9) proves the design boundary: the Seller creates a stable
-- Receivable, Compliance and Risk run scoped workflow processes, the Seller
-- prepares package/discovery/RFQ state, and no concrete Funder is a Phase 1
-- stakeholder.
module CloakRFQ.Test where

import Daml.Script
import DA.Assert ((===))
import CloakRFQ.Lib
import CloakRFQ.Contracts

phase1 : Script ()
phase1 = do
  seller     <- allocateParty "Seller"
  compliance <- allocateParty "Compliance"
  risk       <- allocateParty "Risk"
  funderA    <- allocateParty "FunderA"

  let terms = ReceivableTerms with
        faceValue = 480000.0
        currency = "USD"
        daysToDue = 45
        recoursePreference = Negotiable
        settlementPreference = "T+2"

  let disclosureBoundary = DisclosureBoundary with
        preQuoteDisclosure = "Core facts only"
        packageDisclosure = "No raw Debtor identity or invoice document"
        laterWorkflowDisclosure = "Scoped receipts only"

  -- Seller creates a Receivable (private to the Seller - raw Debtor identity).
  rcv <- submit seller do
    createCmd Receivable with
      seller
      ref = "RCV-9F2A"
      invoiceId = "INV-4471"
      debtorName = "Meridian Retail Group"
      terms
      validityVerified = True

  complianceProcess <- submit seller do
    createCmd ComplianceProcess with
      seller
      complianceParty = compliance
      receivableRef = "RCV-9F2A"
      complianceReceivableData = ComplianceReceivableData with
        sellerEligibilityData = "Seller eligibility evidence"
        rfqEligibilityData = "RFQ eligibility evidence"
        disclosureReviewData = "Disclosure constraints"

  let complianceResult = ComplianceResult with
        sellerEligible = True
        rfqEligible = True
        packageAccessPolicy = "Eligible Funders may request access in Phase 2"
        disclosureBoundary

  complianceAttestation <- submit compliance do
    exerciseCmd complianceProcess RecordComplianceResult with result = complianceResult

  riskProcess <- submit seller do
    createCmd RiskAssessmentProcess with
      seller
      riskAssessor = risk
      receivableRef = "RCV-9F2A"
      riskReceivableData = RiskReceivableData with
        debtorRiskData = "Debtor risk data"
        receivableRiskData = "Receivable performance data"

  let riskResult = RiskResult with
        riskTier = "BBB+"
        riskSummary = "Low"

  riskAttestation <- submit risk do
    exerciseCmd riskProcess RecordRiskAttestation with result = riskResult

  let packageContent = RFQPackageContent with
        funderReceivableData = FunderReceivableData with
          packageSummary = "Core pre-quote facts only"
          paymentProfile = "USD receivable, 45 days to due"
          performanceSummary = "Verified receivable package"
        complianceStatus = "Eligible"
        riskResult
        disclosureBoundary

  let rfqParameters = RFQParameters with
        responseDeadline = "2026-07-01T12:00:00Z"

  rfqPackage <- submit seller do
    createCmd RFQPackage with
      seller
      receivableRef = "RCV-9F2A"
      terms
      packageContent
      rfqParameters

  discovery <- submit seller do
    exerciseCmd rfqPackage CreateDiscoveryListing with
      discoverySummary = RFQDiscoverySummary with
        summary = "USD receivable, 45 days to due, package access handled in Phase 2"

  rfq <- submit seller do
    exerciseCmd rfqPackage OpenRFQRequest

  Some complianceView <- queryContractId seller complianceAttestation
  complianceView.result.sellerEligible === True

  Some riskView <- queryContractId seller riskAttestation
  riskView.result.riskTier === "BBB+"

  Some rfqView <- queryContractId seller rfq
  rfqView.receivableRef === "RCV-9F2A"
  rfqView.terms.faceValue === 480000.0

  -- Phase 1 has no concrete Funder stakeholders.
  None <- queryContractId funderA rcv
  None <- queryContractId funderA complianceAttestation
  None <- queryContractId funderA riskAttestation
  None <- queryContractId funderA discovery
  None <- queryContractId funderA rfq

  pure ()
