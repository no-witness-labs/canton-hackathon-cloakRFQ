-- | CloakRFQ Receipts — Daml Script tests.
--
-- Phase 1 (#9) happy path + the first party-visibility proof (#22): a Funder can
-- see the Blind RFQ it was invited to, but NOT the Seller's Receivable (which
-- carries the raw Debtor identity). That visibility split is enforced by Canton
-- via signatory/observer, not by the UI.
module CloakRFQ.Test where

import Daml.Script
import DA.Assert ((===))
import CloakRFQ

phase1 : Script ()
phase1 = do
  seller      <- allocateParty "Seller"
  compliance  <- allocateParty "Compliance"
  risk        <- allocateParty "Risk"
  coordinator <- allocateParty "Coordinator"
  funderA     <- allocateParty "FunderA"
  funderB     <- allocateParty "FunderB"

  -- Compliance + Risk issue scoped attestations (Seller observes them).
  _ <- submit compliance do
    createCmd ComplianceAttestation with
      complianceParty = compliance, seller
      subject = "Seller eligibility", result = "Eligible"
  _ <- submit risk do
    createCmd RiskAttestation with
      riskAssessor = risk, seller
      subject = "Debtor Risk", result = "BBB+ · Low"

  -- Seller creates a Receivable (private to the Seller — raw Debtor identity).
  rcv <- submit seller do
    createCmd Receivable with
      seller
      ref = "RCV-9F2A"
      invoiceId = "INV-4471"
      faceValue = 480000.0
      currency = "USD"
      daysToDue = 45
      debtorName = "Meridian Retail Group"
      recoursePreference = Negotiable
      settlementPreference = "T+2"
      validityVerified = True

  -- Seller opens the Blind RFQ to two Funders (no raw Debtor identity in it).
  rfq <- submit seller do
    exerciseCmd rcv OpenRFQ with
      coordinator
      funders = [funderA, funderB]
      debtorRisk = "BBB+ · Low"
      receivableValidity = "Verified"

  -- Funder A can see the RFQ it was invited to...
  Some rfqView <- queryContractId funderA rfq
  rfqView.receivableRef === "RCV-9F2A"

  -- ...but NOT the Seller's Receivable (it is not a stakeholder there).
  None <- queryContractId funderA rcv

  pure ()

-- | Phase 2 (#10): Funders submit Private Quotes; the Seller selects the Best
-- Compliant Quote. Proves the headline privacy: competing Funders cannot see
-- each other's quotes, and the SelectedQuote is scoped to Seller + winner only.
phase2 : Script ()
phase2 = do
  seller  <- allocateParty "Seller"
  funderA <- allocateParty "FunderA"
  funderB <- allocateParty "FunderB"
  let rfqRef = "RCV-9F2A"

  -- Funder A quotes higher but demands High disclosure; Funder B is lower with
  -- Minimal disclosure ("disclosure is part of the price").
  qA <- submit funderA do
    createCmd PrivateQuote with
      funder = funderA, seller, rfqRef, funderLabel = "VC-7"
      netPurchasePrice = 468000.0, advanceRatePct = 90
      recourse = Recourse, settlement = "T+1"
      requiredDisclosure = High, debtorNotification = "Required"
      quoteExpiry = "18m", proofOfFundsPassed = True, complianceEligible = True
  qB <- submit funderB do
    createCmd PrivateQuote with
      funder = funderB, seller, rfqRef, funderLabel = "LC-3"
      netPurchasePrice = 465200.0, advanceRatePct = 85
      recourse = NonRecourse, settlement = "T+2"
      requiredDisclosure = Minimal, debtorNotification = "Not required"
      quoteExpiry = "22m", proofOfFundsPassed = True, complianceEligible = True

  -- Privacy: A's quote is visible to A and the Seller, but NOT to Funder B.
  Some _ <- queryContractId funderA qA
  Some _ <- queryContractId seller qA
  None   <- queryContractId funderB qA

  -- Seller selects the Best Compliant Quote (LC-3: lower price, minimal disclosure).
  sel <- submit seller do exerciseCmd qB Accept

  -- The SelectedQuote is scoped to Seller + winner (Funder B); Funder A can't see it.
  Some _ <- queryContractId seller sel
  Some _ <- queryContractId funderB sel
  None   <- queryContractId funderA sel

  -- Funder A's unselected quote stays active — the Seller-controlled fallback pool.
  Some _ <- queryContractId seller qA

  pure ()

-- A reusable Private Quote submission for the settlement tests.
submitQuote : Party -> Party -> Text -> Decimal -> DisclosureLevel -> Text -> Script (ContractId PrivateQuote)
submitQuote funder seller rfqRef price disc notify =
  submit funder do
    createCmd PrivateQuote with
      funder, seller, rfqRef, funderLabel = "Funder"
      netPurchasePrice = price, advanceRatePct = 85
      recourse = NonRecourse, settlement = "T+2"
      requiredDisclosure = disc, debtorNotification = notify
      quoteExpiry = "22m", proofOfFundsPassed = True, complianceEligible = True

-- | Phase 3 (#11) happy path: On-Ledger Demo Settlement. Proves the Auditor
-- receives ONLY the Scoped Compliance Receipt — not the settlement result.
phase3 : Script ()
phase3 = do
  seller  <- allocateParty "Seller"
  funderB <- allocateParty "FunderB"
  auditor <- allocateParty "Auditor"
  let rfqRef = "RCV-9F2A"

  qB  <- submitQuote funderB seller rfqRef 465200.0 Minimal "Not required"
  sel <- submit seller do exerciseCmd qB Accept
  assetB <- submit funderB do createCmd DemoSettlementAsset with owner = funderB, amount = 465200.0
  (res, rcpt) <- submit funderB do exerciseCmd sel Settle with funderAssetCid = assetB, auditor, viaFallback = False

  -- Auditor sees the scoped receipt...
  Some r <- queryContractId auditor rcpt
  r.settlementStatus === "Completed"
  -- ...but NOT the settlement result (Seller + Funder only).
  None <- queryContractId auditor res
  -- Seller was paid the Demo Settlement Asset.
  [(_, a)] <- query @DemoSettlementAsset seller
  a.amount === 465200.0
  pure ()

-- | Phase 3 failure/fallback branch: the selected Funder fails, the Seller
-- promotes a fallback quote, and it settles via fallback.
phase3Fallback : Script ()
phase3Fallback = do
  seller  <- allocateParty "Seller"
  funderA <- allocateParty "FunderA"
  funderB <- allocateParty "FunderB"
  auditor <- allocateParty "Auditor"
  let rfqRef = "RCV-9F2A"

  qA   <- submitQuote funderA seller rfqRef 468000.0 High "Required"
  qB   <- submitQuote funderB seller rfqRef 465200.0 Minimal "Not required"
  selB <- submit seller do exerciseCmd qB Accept

  -- Commitment Failure on the selected quote.
  submit seller do exerciseCmd selB Fail

  -- Seller promotes Funder A from the fallback pool and settles via fallback.
  selA <- submit seller do exerciseCmd qA Accept
  assetA <- submit funderA do createCmd DemoSettlementAsset with owner = funderA, amount = 468000.0
  (_, rcpt) <- submit funderA do exerciseCmd selA Settle with funderAssetCid = assetA, auditor, viaFallback = True

  Some r <- queryContractId auditor rcpt
  r.settlementStatus === "Completed via fallback"
  r.fallbackUsed === True
  pure ()
