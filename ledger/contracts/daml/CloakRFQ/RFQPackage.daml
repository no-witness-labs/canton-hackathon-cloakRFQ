-- | Phase 1 Seller-created RFQ package anchor.
module CloakRFQ.RFQPackage where

import CloakRFQ.Lib
import CloakRFQ.Compliance
import CloakRFQ.Risk
import CloakRFQ.Receivable

-- | Thin on-ledger package anchor. The full RFQ package is assembled from
-- this contract plus linked authority certificates and package metadata.
template RFQPackage
  with
    seller : Party
    packageId : Text
    receivableCid : ContractId Receivable
    terms : ReceivableTerms
    packageContent : RFQPackageContent
    rfqParameters : RFQParameters
    complianceCertificateCid : ContractId ComplianceCertificate
    riskCertificateCid : ContractId RiskCertificate
  where
    signatory seller
    ensure hasValidReceivableTerms terms
