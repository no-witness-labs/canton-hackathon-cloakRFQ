# Copy to .env.local to point the app at a remote participant.
# LOCAL SANDBOX (default): leave all unset — /v2 proxies to http://127.0.0.1:6864
# CANTON DEVNET (Seaport / fivenorth): set all of these; the secret stays server-side.
CLOAKRFQ_LEDGER_TARGET=https://ledger-api.validator.devnet.sandbox.fivenorth.io
CLOAKRFQ_OIDC_TOKEN_URL=https://auth.sandbox.fivenorth.io/application/o/token/
CLOAKRFQ_OIDC_CLIENT_ID=validator-devnet-m2m
CLOAKRFQ_OIDC_CLIENT_SECRET=<your-client-secret>
CLOAKRFQ_OIDC_AUDIENCE=validator-devnet-m2m
CLOAKRFQ_OIDC_SCOPE=daml_ledger_api

# SELF-SERVICE (Level 1) — set on a shared/Vercel deploy so each visitor gets their
# OWN isolated party set (no manual bootstrap-devnet.py). Requires the DAR already
# uploaded to the participant (one-time). Leave unset for the single-shared-deal flow.
# CLOAKRFQ_SESSION_PROVISIONING=1
# CLOAKRFQ_LEDGER_USER_ID=6
# CLOAKRFQ_PARTY_NAMESPACE=1220a14ca128063b8dc9d1ebb0bd22633be9f2168500f4dbc1ecaeb1855b14e5acf8
